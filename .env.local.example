NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend（寄送確認信 + 管理員通知）
# 到 resend.com 申請免費帳號取得 API Key
# 免費方案每月 3000 封，足夠初期使用
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# 管理員通知信收件地址（有新租借申請時通知此信箱）
ADMIN_EMAIL=

# LINE Messaging API（OA 後台 > Basic settings / Messaging API）
# webhook 簽章驗證、推播訊息都要用
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 管理員審核用的 LINE 目的地：優先吃 GROUP_ID，兩者至少要有一個
# GROUP_ID 由 OA 加入群組後，webhook 會自動回報到 ADMIN_LINE_USER_ID 私訊
ADMIN_LINE_GROUP_ID=
ADMIN_LINE_USER_ID=

# LIFF（客戶端付款回報頁 /liff/payment-report 用，登入 LINE Developers 建立）
NEXT_PUBLIC_LINE_LIFF_ID=

# /api/line/notify-token 簽發簽章用的獨立密鑰，未設定時會 fallback 用
# SUPABASE_SERVICE_ROLE_KEY 代替（可用但不建議長期依賴，兩者用途不同）
# 產生方式：openssl rand -hex 32
LINE_NOTIFY_SECRET=

# Vercel Cron（/api/cron/reminder，付款提醒 + 逾期自動取消）保護用
# 產生方式：openssl rand -hex 32
CRON_SECRET=
